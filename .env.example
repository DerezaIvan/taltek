# Directus (опционально — без них сайт работает на локальных constants)

# Публичный URL Directus API
PUBLIC_DIRECTUS_URL=http://localhost:8055

# Read-only token для сборки (не коммитить!)
DIRECTUS_TOKEN=

# Postgres (profile cms)
POSTGRES_USER=directus
POSTGRES_PASSWORD=directus
POSTGRES_DB=directus

# Directus bootstrap
DIRECTUS_SECRET=replace-with-a-long-random-secret
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=directus
DIRECTUS_PUBLIC_URL=http://localhost:8055
