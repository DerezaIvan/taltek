{
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": true,
  "semi": true,
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "trailingComma": "es5",
  "bracketSameLine": false,
  "printWidth": 100,
  "endOfLine": "auto",
  "plugins": ["prettier-plugin-svelte"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte",
        "pluginSearchDirs": ["."],
        "svelteSortOrder": "scripts-styles-markup-options",
        "svelteStrictMode": false,
        "svelteBracketNewLine": false,
        "svelteAllowShorthand": true,
        "svelteIndentScriptAndStyle": true
      }
    },
    {
      "files": ["*.scss", "*.css"],
      "options": {
        "parser": "scss"
      }
    }
  ]
}
